CONFIG__GIT_PROVIDER=gitlab
CONFIG__AI_HANDLER=codex_cli
CONFIG__MODEL=gpt-5.4
CONFIG__AI_TIMEOUT=600
CONFIG__RESPONSE_LANGUAGE=zh-CN

GITLAB__URL=https://your.gitlab.host
GITLAB__PERSONAL_ACCESS_TOKEN=glpat-xxxx
GITLAB__SHARED_SECRET=replace-me
GITLAB__AUTH_TYPE=private_token

CODEX_HOME=/var/lib/pr-agent/.codex
CODEX_CLI__COMMAND=codex
PORT=3000
